<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/userdocuments/db" VERSION="2026031200" COMMENT="XMLDB file for local_userdocuments plugin."
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_userdocuments_guardian" COMMENT="Stores guardian information for users.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to user.id"/>
        <FIELD NAME="guardian_name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Guardian full name"/>
        <FIELD NAME="guardian_contact" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" COMMENT="Guardian phone number"/>
        <FIELD NAME="guardian_relationship" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false" COMMENT="Relationship to user"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_unique" UNIQUE="true" FIELDS="userid" COMMENT="One guardian record per user."/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
